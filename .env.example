# 讯飞语音服务凭证配置
#
# 请复制此文件为 .env 并填入你的真实凭证
# 此文件不会提交到 Git，请妥善保管
#
# 获取凭证步骤：
# 1. 注册讯飞开放平台：https://www.xfyun.cn
# 2. 创建应用，获取 APPID、API Key、API Secret
# 3. 开通「语音听写」和「语音合成」服务

# 应用ID
XFYUN_APP_ID=your_app_id_here

# API密钥
XFYUN_API_KEY=your_api_key_here

# API密钥密文
XFYUN_API_SECRET=your_api_secret_here

# 语音听写 WebSocket 地址（可选，有默认值）
# XFYUN_ASR_URL=wss://iat-api.xfyun.cn/v2/iat

# 语音合成 WebSocket 地址（可选，有默认值）
# 超拟人语音合成 API
# XFYUN_TTS_URL=wss://cbm01.cn-huabei-1.xf-yun.com/v1/private/mcd9m97e6

# TTS音色（可选，默认 x6_wumeinv_pro）
# 超拟人系列：x6_wumeinv_pro(超拟人女声), x6_shaofeng_pro(超拟人男声)
# 普通音色：xiaoyan(晓燕), aisxping(小萍), aisjinger(婧儿)
# XFYUN_VOICE_TYPE=x6_wumeinv_pro